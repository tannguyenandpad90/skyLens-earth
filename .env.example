# ============================================================
# SkyLens Earth — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skylens_earth?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Flight Data Provider ---
# Sign up at https://aviationstack.com (free tier: 500 req/month)
AVIATIONSTACK_API_KEY=""

# Fallback provider (optional)
# AERODATABOX_API_KEY=""

# --- Mapbox ---
# Sign up at https://mapbox.com (free tier: 50k loads/month)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Claude AI ---
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- App Config ---
NEXT_PUBLIC_API_URL=""
NODE_ENV="development"
